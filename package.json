{
  "name": "@mklimov1/vite-game-forge",
  "version": "0.0.5",
  "type": "module",
  "bin": {
    "infra-init": "./dist/cli/init.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./assetpack": {
      "import": "./dist/assetpack.js",
      "types": "./dist/assetpack.d.ts"
    },
    "./tsconfig.base.json": "./infra/shared/tsconfig.base.json"
  },
  "files": [
    "dist",
    "globals.d.ts",
    "infra"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/assetpack.ts src/cli/init.ts --format esm --dts --no-splitting --external @assetpack/core --external vite-plugin-singlefile --external vite-plugin-zip-pack",
    "link": "npm run build && npm link"
  },
  "devDependencies": {
    "@assetpack/core": "^1.7.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "@assetpack/core": "^1.0.0",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@assetpack/core": {
      "optional": true
    }
  },
  "dependencies": {
    "vite-plugin-singlefile": "^2.3.2",
    "vite-plugin-zip-pack": "^1.2.4"
  }
}
