{
  "name": "vite-plugin-playable",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./assetpack": {
      "import": "./dist/assetpack.js",
      "types": "./dist/assetpack.d.ts"
    }
  },
  "files": [
    "dist",
    "globals.d.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/assetpack.ts --format esm --dts --external @assetpack/core --external vite-plugin-singlefile",
    "link": "npm run build && npm link"
  },
  "devDependencies": {
    "@assetpack/core": "^1.7.0",
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "@assetpack/core": "^1.0.0",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@assetpack/core": {
      "optional": true
    }
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
